{
  "name": "@joker53/nodewipe",
  "version": "0.1.2",
  "description": "Find and reclaim disk space from stray dev artifacts — node_modules, Python venvs, Rust target/, Java build output, and more (Rust engine, npm shim)",
  "keywords": [
    "node_modules",
    "venv",
    "virtualenv",
    "disk-space",
    "cleanup",
    "cli",
    "cargo",
    "target",
    "pycache",
    "monorepo"
  ],
  "bin": {
    "nodewipe": "bin/nodewipe.js"
  },
  "scripts": {
    "postinstall": "node scripts/download-binary.js"
  },
  "files": [
    "bin",
    "scripts"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KADHIRAVANEG/nodewipe.git"
  },
  "engines": {
    "node": ">=16"
  }
}
